  "keyFeatures": [
    "Browser automation with Playwright stealth mode for realistic traffic capture",
    "HAR (HTTP Archive) recording of all network traffic",
    "AI-powered API client generation using Claude 4.6",
    "Four modes: manual browser capture, engineer (re-process), autonomous agent, and collector",
    "Multi-SDK support: Claude Agent SDK and OpenCode SDK",
    "Tag system for fine-grained control (@record-only, @codegen, @docs, @id)",
    "Cost tracking with token usage and cache support",
    "Claude Code plugin and Chrome extension integrations",
    "Multi-language output: Python, JavaScript, TypeScript",
    "Session history with full message logs"
  ],
